{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault Desk",
  "version": "0.0.0",
  "identifier": "dev.vaultdesk.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:sidecar && pnpm build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vault Desk",
        "width": 1440,
        "height": 940,
        "minWidth": 760,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/vault-core"],
    "resources": ["resources/core"],
    "icon": [],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": true
    }
  }
}
