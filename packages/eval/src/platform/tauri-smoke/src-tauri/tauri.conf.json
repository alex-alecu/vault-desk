{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault Desk M0 Capability Smoke",
  "version": "0.0.0",
  "identifier": "dev.vaultdesk.m0-capability-smoke",
  "build": {
    "frontendDist": "../.generated/frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vault Desk M0 Capability Smoke",
        "width": 560,
        "height": 280,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": [],
    "externalBin": ["binaries/vault-m0-sidecar"]
  }
}
